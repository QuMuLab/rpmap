
(define (problem bdi-item)
	(:domain bdi)
	(:objects l1 l2 l3 - loc)
	(:depth 2)
	(:task valid_generation)
	(:init-type complete)
	(:init 
		(connected l1 l2)
		(connected l3 l2)
		(connected l2 l3)
		(at a l1)
		![d, a](!secret a)
		(at b l1)
		(connected l2 l1)
	)
	(:goal [i, b](secret a))
	(:plan 
		![d, a](!secret a)
		![d, a](!secret a)
	)
)
