;{include:domain.pdkbddl}

(define (problem witch-collect-item)

    (:domain suspicious_witches)

    (:objects 
        l1 l2 l3 - loc
        eye_of_newt toe_of_frog - item
    )

    (:depth 2)
    (:task valid_assessment)

    (:init-type complete)
    (:init
        ; locations + connections
        (connected l1 l2)
        (connected l2 l1)
        (connected l2 l3)
        (connected l3 l2)
        (at alice l1)
        (at cindy l1)
        (at bob l2)
        (at derek l2)
        (at evelyn l3)
        (item-at eye_of_newt l1)
        (item-at toe_of_frog l3)

        ; identities
        (witch bob)
        (civilian alice)
        (civilian cindy)

        ; diff hack since equality is currently bugged in the planner
        (diff alice bob)
        (diff alice cindy)

        (diff bob alice)
        (diff bob cindy)

        (diff cindy alice)
        (diff cindy bob)

        ; beliefs
        <alice>(witch bob)
        !<cindy>(witch bob)
    )

    (:goal (and 
        (collected eye_of_newt)
        [alice](witch bob)
        <cindy>(witch bob)    
        )
    )

    (:plan
        (move bob l2 l1)
        (collect-item bob eye_of_newt l1)
    )
)