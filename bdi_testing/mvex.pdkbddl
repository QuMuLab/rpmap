
(define (domain grapevine)
    (:agents a b c d)
    (:requirements :typing)
    (:types loc)

    (:predicates
        {AK}(secret ?l - loc)
        {AK}(secret3 ?l - loc)
        (secret10 ?l - loc)
    )

    (:action test
        :parameters         ()
        :precondition       ()
        :effect             ()
    )
)