
(define (domain grapevine)
    (:agents a b c d)
    (:requirements :typing)
    (:types loc)

    (:predicates
        (secret)
        ; (secret ?agent)
        ; (at ?agent - agent ?l - loc)
        ; (connected ?l1 ?l2 - loc)
        ; {AK}(at ?agent - agent ?l - loc)
        ; {AK}(connected ?l1 ?l2 - loc)
    )

    (:action test
        :parameters         () ; (?a - agent ?l1 ?l2 - loc) 
        :precondition       (and (secret))
        :effect             (and (not(secret)))
    )

