(define (domain bdi)
    (:agents a b)
    (:requirements :typing)
    (:types loc)
    (:predicates
        (secret ?agent)
        {AK}(at ?agent - agent ?l - loc)
        {AK}(connected ?l1 ?l2 - loc)
    )

    (:action move
        :derive-condition   always
        :parameters         (?a - agent ?l1 ?l2 - loc)
        :precondition       (and (at ?a ?l1) (connected ?l1 ?l2))
        :effect             (and (at ?a ?l2) (not(at ?a ?l1)))
    )

    (:action share
        :derive-condition   never
        :parameters         (?a1 ?a2 - agent ?l - loc)
        :precondition       (and (at ?a1 ?l) (at ?a2 ?l) ![b, ?a1](!secret ?a1))
        :effect             (and
                                [d, ?a2](secret ?a2)
                                [i, ?a2](secret ?a2)
                            )
    )
)