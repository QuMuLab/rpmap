(define (domain suspicious_witches)
    ; UNCOMMENT BASED ON THE NUMBER/NAMES OF AGENTS

    ; (:agents alice cindy)
    ; (:agents alice bob cindy derek)
    ; (:agents alice bob cindy derek evelyn)
    (:agents alice bob cindy)
    ; (:agents bob cindy derek evelyn)


    (:types loc item)

    (:requirements)

    (:predicates 
        {AK}(diff ?a1 ?a2 - agent) ; agents are different
        {AK}(connected ?l1 ?l2 - loc) ; locations are connected
        {AK}(at ?ag - agent ?l - loc) ; agent is at a location
        {AK}(item-at ?i - item ?loc - loc) ; item is at a location
        {AK}(town-exit ?l - loc) ; location is the exit of the town
        (witch ?ag - agent) ; agent is a witch
        (civilian ?ag - agent) ; agent is a civilian
        {AK}(collected ?i - item) ; item has been collected
        {AK}(cursed ?ag - agent) ; agent is cursed (rip)
        {AK}(paranoid ?ag - agent) ; agent is paranoid
        {AK}(hates ?a1 ?a2 - agent) ; agent 1 hates agent 2
        {AK}(threatened-by ?a1 ?a2 - agent) ; agent 1 is threatened by agent 2
        {AK}(witch-hunting ?a1 ?a2 - agent)
        (accused-by ?a1 ?a2 - agent)  ; agent 1 is accused by agent 2
        {AK}(stealthy ?ag - agent) ; agent is stealthy
        {AK}(fled ?ag - agent) ; agent has fled the town
        {AK}(executed ?ag - agent) ; agent has been executed
        {AK}(sycophant ?a1 ?a2 - agent) ; Agent 1 is a sycophant to Agent 2
        {AK}(influencer ?ag - agent)

        {AK}(desire-accuse ?a1 ?a2 - agent)
        {AK}(desire-accuse-paranoid ?a1 ?a2 - agent)
        {AK}(desire-accuse-lying-hatred ?a1 ?a2 - agent)
        {AK}(desire-accuse-random-accused ?a1 ?a2 - agent)
        {AK}(intend-accuse ?a1 ?a2 - agent)
        {AK}(intend-accuse-paranoid ?a1 ?a2 - agent)
        {AK}(intend-accuse-lying-hatred ?a1 ?a2 - agent)
        {AK}(intend-accuse-random-accused ?a1 ?a2 - agent)

        {AK}(desire-flee ?ag - agent)
        {AK}(intend-flee ?ag - agent)

        {AK}(desire-defend-earnestly ?a1 ?a2 ?a3 - agent)
        {AK}(desire-defend-threatened ?a1 ?a2 ?a3 - agent)
        {AK}(intend-defend-earnestly ?a1 ?a2 ?a3 - agent)
        {AK}(intend-defend-threatened ?a1 ?a2 ?a3 - agent)
          
    )



    ; BURN THE WITCH ACTION: UNCOMMENT ACCORDING TO THE # OF CIVILIANS

    ; (:action burn-the-witch-one-civ
    ;     :derive-condition never
    ;     :parameters (?a1 ?a2 - agent ?l - loc)
    ;     :precondition (and
    ;         (diff ?a1 ?a2)  
    ;         (at ?a1 ?l)
    ;         (at ?a2 ?l)
    ;         (witch-hunting ?a1 ?a2)
    ;     )
    ;     :effect (and
    ;         (executed ?a2)
    ;     )
    ; )
    ; (:action burn-the-witch-two-civ
    ;     :derive-condition never
    ;     :parameters (?a1 ?a2 ?a3 - agent ?l - loc)
    ;     :precondition (and
    ;         (diff ?a1 ?a2)
    ;         (diff ?a2 ?a3)   
    ;         (diff ?a1 ?a3)   

    ;         (at ?a1 ?l)
    ;         (at ?a2 ?l)
    ;         (at ?a3 ?l)
    ;         (witch-hunting ?a1 ?a3)
    ;         (witch-hunting ?a2 ?a3)
    ;     )
    ;     :effect (and
    ;         (executed ?a3)
    ;     )
    ; )
    (:action burn-the-witch-three-civ
        :derive-condition never
        :parameters (?a1 ?a2 ?a3 ?a4 - agent ?l - loc)
        :precondition (and
            (diff ?a1 ?a2)
            (diff ?a1 ?a3)   
            (diff ?a1 ?a4)   
            (diff ?a2 ?a3)
            (diff ?a2 ?a4)
            (diff ?a3 ?a4)
             
            (at ?a1 ?l)
            (at ?a2 ?l)
            (at ?a3 ?l)
            (at ?a4 ?l)
            (witch-hunting ?a1 ?a4)
            (witch-hunting ?a2 ?a4)
            (witch-hunting ?a3 ?a4)
        )
        :effect (and
            (executed ?a4)
        )
    )
    ; (:action burn-the-witch-four-civ
    ;     :derive-condition never
    ;     :parameters (?a1 ?a2 ?a3 ?a4 ?a5 - agent ?l - loc)
    ;     :precondition (and
    ;         (diff ?a1 ?a2)
    ;         (diff ?a1 ?a3)    
    ;         (diff ?a1 ?a4)
    ;         (diff ?a1 ?a5)
    ;         (diff ?a2 ?a3)
    ;         (diff ?a2 ?a4)
    ;         (diff ?a2 ?a5)
    ;         (diff ?a3 ?a4)
    ;         (diff ?a3 ?a5)
    ;         (diff ?a4 ?a5)
    ;         (at ?a1 ?l)
    ;         (at ?a2 ?l)
    ;         (at ?a3 ?l)
    ;         (at ?a4 ?l)
    ;         (at ?a5 ?l)
    ;         (witch-hunting ?a1 ?a5)
    ;         (witch-hunting ?a2 ?a5)
    ;         (witch-hunting ?a3 ?a5)
    ;         (witch-hunting ?a4 ?a5)
    ;     )
    ;     :effect (and
    ;         (executed ?a5)
    ;     )
    ; )



    ; PERFORM SPELL ACTION: UNCOMMENT ACCORDING TO THE # OF WITCHES

    ; two (unique) witches gather at the same location with all the collected items to curse all the civilians
    ; (:action perform-spell-two
    ;     :derive-condition always
    ;     :parameters (?l - loc ?w1 ?w2 - agent)
    ;     :precondition (and
    ;             (witch ?w1)
    ;             (witch ?w2)
    ;             (at ?w1 ?l)
    ;             (at ?w2 ?l)
    ;             (diff ?w1 ?w2)
    ;             (forall (?i - item) (collected ?i))
    ;         )
    ;     :effect (and 
    ;         (forall (?ag - agent) (when (civilian ?ag) (cursed ?ag))) ; change to just changing them to witches?
    ;     )
    ; )
    (:action perform-spell-three
        :derive-condition always
        :parameters (?l - loc ?w1 ?w2 ?w3 - agent)
        :precondition (and
                (witch ?w1)
                (witch ?w2)
                (witch ?w3)
                (at ?w1 ?l)
                (at ?w2 ?l)
                (at ?w3 ?l)
                (diff ?w1 ?w2)
                (diff ?w2 ?w3)
                (diff ?w1 ?w3)
                (forall (?i - item) (collected ?i))
            )
        :effect (and 
            (forall (?ag - agent) (when (civilian ?ag) (cursed ?ag))) 
        )
    )
    ; (:action perform-spell-four
    ;     :derive-condition always
    ;     :parameters (?l - loc ?w1 ?w2 ?w3 ?w4 - agent)
    ;     :precondition (and
    ;             (witch ?w1)
    ;             (witch ?w2)
    ;             (witch ?w3)
    ;             (witch ?w4)
    ;             (at ?w1 ?l)
    ;             (at ?w2 ?l)
    ;             (at ?w3 ?l)
    ;             (at ?w4 ?l)
    ;             (diff ?w1 ?w2)
    ;             (diff ?w1 ?w3)
    ;             (diff ?w1 ?w4)
    ;             (diff ?w2 ?w3)
    ;             (diff ?w2 ?w4)
    ;             (diff ?w3 ?w4)
    ;             (forall (?i - item) (collected ?i))
    ;         )
    ;     :effect (and 
    ;         (forall (?ag - agent) (when (civilian ?ag) (cursed ?ag)))
    ;     )
    ; )

    ; agents can move around
    (:action move
        :derive-condition   always
        :parameters         (?ag - agent ?l1 ?l2 - loc)
        :precondition       (and (at ?ag ?l1) (connected ?l1 ?l2) (not (fled ?ag)))
        :effect             (and (at ?ag ?l2) (not (at ?ag ?l1)))
    )

    (:action desire-to-accuse
        :derive-condition never
        :parameters (?a1 ?acsd - agent)
        :precondition (and 
                        (civilian ?a1) ; agent 1 is civilian
                        (diff ?a1 ?acsd) ; agents are unique
                        [?a1](witch ?acsd) ; agent 1 believes agent acsd is a witch
        )
        :effect (and 
            (desire-accuse ?a1 ?acsd) 
        )
    )

    (:action desire-to-accuse-paranoid
        :derive-condition never
        :parameters (?a1 ?acsd - agent)
        :precondition (and 
                        (civilian ?a1) ; agent 1 is civilian
                        (diff ?a1 ?acsd) ; agents are unique
                        <?a1>(witch ?acsd) ; agent 1 thinks it's possible agent acsd is a witch
                        ![?a1](witch ?acsd)
                        (paranoid ?a1) ; agent 1 is paranoid
        )
        :effect (and 
            (desire-accuse-paranoid ?a1 ?acsd) 
        )
    )

    (:action desire-to-accuse-lying
        :derive-condition never
        :parameters (?a1 ?acsd - agent)
        :precondition (and 
                        (diff ?a1 ?acsd) ; agents are unique
                        !<?a1>(witch ?acsd) ; a1 does not believe agent acsd is a witch
                        (hates ?a1 ?acsd) ; a1 hates acsd
        )
        :effect (and 
            (desire-accuse-lying-hatred ?a1 ?acsd) 
        )
    )

    (:action desire-to-accuse-accused
        :derive-condition never
        :parameters (?a1 ?acsd ?acsr - agent)
        :precondition (and 
                        (diff ?a1 ?acsd) ; agents are unique (note: accused and accuser CAN be the same)
                        (diff ?a1 ?acsr)
                        (accused-by ?a1 ?acsr) ; a1 accused by acsr
                        [?a1](accused-by ?a1 ?acsr)
        )
        :effect (and 
            (desire-accuse-random-accused ?a1 ?acsd) 
        )
    )

    (:action copy-desire-to-accuse
        :derive-condition never
        :parameters (?syc ?a2 ?acsd - agent ?l - loc)
        :precondition (and 
            (sycophant ?syc ?a2)
            (civilian ?syc)
            (at ?syc ?l)
            (at ?a2 ?l)
            (diff ?syc ?a2)
            (diff ?syc ?acsd)
            (desire-accuse ?a2 ?acsd)
        )
        :effect (and 
            (desire-accuse ?syc ?acsd)
            [?syc](witch ?acsd)
        )
    )
    (:action copy-desire-to-accuse-paranoid
        :derive-condition never
        :parameters (?syc ?a2 ?acsd - agent ?l - loc)
        :precondition (and 
            (sycophant ?syc ?a2)
            (civilian ?syc)
            (at ?syc ?l)
            (at ?a2 ?l)
            (diff ?syc ?a2)
            (diff ?syc ?acsd)
            (desire-accuse-paranoid ?a2 ?acsd)
        )
        :effect (and 
            (desire-accuse-paranoid ?syc ?acsd)
            <?syc>(witch ?acsd)
            ![?syc](witch ?acsd)
            (paranoid ?syc)
        )
    )
    (:action copy-desire-to-accuse-lying-hatred
        :derive-condition never
        :parameters (?syc ?a2 ?acsd - agent ?l - loc)
        :precondition (and 
            (sycophant ?syc ?a2)
            (civilian ?syc)
            (at ?syc ?l)
            (at ?a2 ?l)
            (diff ?syc ?a2)
            (diff ?syc ?acsd)
            (desire-accuse-lying-hatred ?a2 ?acsd)
        )
        :effect (and 
            (desire-accuse-lying-hatred ?syc ?acsd)
            !<?syc>(witch ?acsd)
            (hates ?syc ?acsd)
        )
    )
    (:action copy-desire-to-accuse-accused
        :derive-condition never
        :parameters (?syc ?a2 ?acsd - agent ?l - loc)
        :precondition (and 
            (sycophant ?syc ?a2)
            (civilian ?syc)
            (at ?syc ?l)
            (at ?a2 ?l)
            (diff ?syc ?a2)
            (diff ?syc ?acsd)
            (desire-accuse-random-accused ?a2 ?acsd)
        )
        :effect (and 
            ; in this case, the sycophant jumps on the accusation but don't become accused themselves
            (desire-accuse-random-accused ?syc ?acsd)
        )
    )

    (:action influence
        :derive-condition never
        :parameters (?inf - agent ?l - loc)
        :precondition (and 
            (influencer ?inf)
            (at ?inf ?l)
        )
        :effect (and 
            (forall ?ag - agent 
                (and
                    (when 
                        (and
                            (at ?ag ?l)
                            (civilian ?ag)
                        ) 
                        (sycophant ?ag ?inf)
                    )
                )
            )
        )
    )

    (:action intend-to-accuse
        :derive-condition never
        :parameters (?a1 ?acsd - agent)
        :precondition (and 
            (desire-accuse ?a1 ?acsd) 
        )
        :effect (and 
            (intend-accuse ?a1 ?acsd)
        )
    )

    (:action intend-to-accuse-paranoid
        :derive-condition never
        :parameters (?a1 ?acsd - agent)
        :precondition (and (desire-accuse-paranoid ?a1 ?acsd) )
        :effect (and (intend-accuse-paranoid ?a1 ?acsd))
    )

    (:action intend-to-accuse-lying
        :derive-condition never
        :parameters (?a1 ?acsd - agent)
        :precondition (and (desire-accuse-lying-hatred ?a1 ?acsd) )
        :effect (and (intend-accuse-lying-hatred ?a1 ?acsd))
    )

    (:action intend-to-accuse-accused
        :derive-condition never
        :parameters (?a1 ?acsd - agent)
        :precondition (and (desire-accuse-random-accused ?a1 ?acsd) )
        :effect (and (intend-accuse-random-accused ?a1 ?acsd))
    )

    ; civilian tells another agent that they truthfully believe another agent is a witch 
    (:action civilian-whisper-accuse
        :derive-condition   never
        :parameters         (?a1 ?a2 ?a3 - agent ?l - loc)
        :precondition       (and 
                                (intend-accuse ?a1 ?a3)
                                (at ?a1 ?l) ; telling and hearing agents at the same loc
                                (at ?a2 ?l) 
                                (diff ?a1 ?a2) ; all agents are unique
                                (diff ?a2 ?a3)
                                !<?a1>(witch ?a2) ; telling agent doesn't think it possible that listening agent is a witch
                            )
        :effect             (and
                                (accused-by ?a3 ?a1)
                                [?a2](accused-by ?a3 ?a1)
                                [?a1](accused-by ?a3 ?a1)
                                ; when the listening agent is a civilian and they think it's possible the third agent is a witch
                                ; and they don't think it's possible the telling agent is a witch
                                (when 
                                    (and
                                        (civilian ?a2)
                                        <?a2>(witch ?a3)
                                        !<?a2>(witch ?a1)
                                    )
                                    ; the listening agent believes the third agent is a witch
                                    [?a2](witch ?a3)
                                )
                                ; when the listening agent is a civilian and they think it's possible the telling agent is a witch
                                ; and they don't think it's possible the third agent is a witch
                                (when 
                                    (and
                                        (civilian ?a2)
                                        <?a2>(witch ?a1)
                                        !<?a2>(witch ?a3)
                                    )
                                    ; the listening agent believes the telling agent is a witch
                                    [?a2](witch ?a1)
                                )
                                (when 
                                    (witch ?a2)
                                    [?a2][?a1](witch ?a3)
                                )
                            )
    )

    (:action civilian-paranoid-accuse
        :derive-condition   never
        :parameters (?a1 ?a2 - agent ?l - loc)
        :precondition (and 
                        (intend-accuse-paranoid ?a1 ?a2)
                        (at ?a1 ?l) ; a1 at loc
                    ) 
        :effect (and
            (accused-by ?a2 ?a1)
            (forall ?ag - agent 
                (and
                    (when (at ?ag ?l) [?ag](accused-by ?a2 ?a1))
                    ; when civilian at the same location does not believe it possible a1 is a witch
                    ; and believes it possible a2 is a witch
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            !<?ag>(witch ?a1)
                            <?ag>(witch ?a2)
                        )
                        [?ag](witch ?a2) ; agent believes a2 is a witch
                    )
                    ; same condition as prev
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            !<?ag>(witch ?a1)
                            <?ag>(witch ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )
                    ; when civilian at the same location does not believe it possible a2 is a witch
                    ; and believes it possible a1 is a witch
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            <?ag>(witch ?a1)
                            !<?ag>(witch ?a2)
                        )
                        [?ag](witch ?a1) ; agent believes a1 is a witch
                    )
                    ; same condition as prev
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            <?ag>(witch ?a1)
                            !<?ag>(witch ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )
                    ; when there's a witch at the same location 
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (witch ?ag)
                            (diff ?ag ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )                                     
                )
            )
        )
    )

    (:action lie-accuse-hatred
        :derive-condition   never
        :parameters (?a1 ?a2 - agent ?l - loc)
        :precondition (and 
                        (intend-accuse-lying-hatred ?a1 ?a2)
                        (at ?a1 ?l) ; a1 at loc
                    )
        :effect (and
            (accused-by ?a2 ?a1)
            (forall ?ag - agent 
                (and
                    (when (at ?ag ?l) [?ag](accused-by ?a2 ?a1))
                    ; when civilian at the same location does not believe it possible a1 is a witch
                    ; and believes it possible a2 is a witch
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            !<?ag>(witch ?a1)
                            <?ag>(witch ?a2)
                        )
                        [?ag](witch ?a2) ; agent believes a2 is a witch
                    )
                    ; same condition as prev
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            !<?ag>(witch ?a1)
                            <?ag>(witch ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )
                    ; when civilian at the same location does not believe it possible a2 is a witch
                    ; and believes it possible a1 is a witch
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            <?ag>(witch ?a1)
                            !<?ag>(witch ?a2)
                        )
                        [?ag](witch ?a1) ; agent believes a1 is a witch
                    )
                    ; same condition as prev
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            <?ag>(witch ?a1)
                            !<?ag>(witch ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )
                    ; when there's a witch at the same location 
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (witch ?ag)
                            (diff ?ag ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )                                 
                )
            )
        )
    )

    (:action random-accuse-accused
        :derive-condition   never
        :parameters (?a1 ?a2 - agent ?l - loc)
        :precondition (and 
                        (intend-accuse-random-accused ?a1 ?a2)
                        (at ?a1 ?l) ; a1 at loc
                    )
        :effect (and
            (accused-by ?a2 ?a1)
            (forall ?ag - agent 
                (and
                    (when (at ?ag ?l) [?ag](accused-by ?a2 ?a1))
                    ; when civilian at the same location does not believe it possible a1 is a witch
                    ; and believes it possible a2 is a witch   
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            !<?ag>(witch ?a1)
                            <?ag>(witch ?a2)
                        )
                        [?ag](witch ?a2) ; agent believes a2 is a witch
                    )
                    ; same condition as prev
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            !<?ag>(witch ?a1)
                            <?ag>(witch ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )
                    ; when civilian at the same location does not believe it possible a2 is a witch
                    ; and believes it possible a1 is a witch
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            <?ag>(witch ?a1)
                            !<?ag>(witch ?a2)
                        )
                        [?ag](witch ?a1) ; agent believes a1 is a witch
                    )
                    ; same condition as prev
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (civilian ?ag)
                            (diff ?ag ?a1)
                            (diff ?ag ?a2)
                            <?ag>(witch ?a1)
                            !<?ag>(witch ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )
                    ; when there's a witch at the same location 
                    (when 
                        (and 
                            (at ?ag ?l) 
                            (witch ?ag)
                            (diff ?ag ?a2)
                        )
                        [?ag][?a1](witch ?a2) ; agent believes a1 believes a2 is a witch
                    )                                 
                )
            )
        )
    )

    (:action desire-to-defend-earnestly
        :derive-condition never
        :parameters (?defender ?acsd ?acsr - agent)
        :precondition (and 
            !<?defender>(witch ?acsd) 
            (accused-by ?acsd ?acsr)
            [?defender](accused-by ?acsd ?acsr)
            (diff ?defender ?acsd)
            (diff ?defender ?acsr)
            (diff ?acsd ?acsr)
        )
        :effect (and 
            (desire-defend-earnestly ?defender ?acsd ?acsr)
        )
    )
    (:action intend-to-defend-earnestly
        :derive-condition never
        :parameters (?defender ?acsd ?acsr - agent)
        :precondition (and 
            (desire-defend-earnestly ?defender ?acsd ?acsr)
        )
        :effect (and 
            (intend-defend-earnestly ?defender ?acsd ?acsr)
        )
    )

    (:action defend-earnestly
        :derive-condition never
        :parameters (?defender ?acsd ?acsr - agent ?l - loc)
        :precondition (and 
            (intend-defend-earnestly ?defender ?acsd ?acsr)
            (at ?defender ?l)
            (at ?acsd ?l)
        )
        :effect (and 
            (forall ?ag - agent (and
                    (when (at ?ag ?l) [?ag](accused-by ?acsd ?acsr))
                    ; if agent believes it's possible the defender is a witch,
                    ; and they strongly believe the accused is a witch, 
                    ; they now believe the defender is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            ; note: this could include the original accuser
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            [?ag](witch ?acsd)
                            <?ag>(witch ?defender)
                        )
                        [?ag](witch ?defender)
                    )
                    ; if agent doesn't believe it's possible the accused is a witch, 
                    ; and they believe the defender is a witch,
                    ; they now don't believe the defender is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            !<?ag>(witch ?acsd)
                            [?ag](witch ?defender)
                        )
                        ![?ag](witch ?defender)
                    )
                    ; if agent strongly believes the defender is a witch, 
                    ; and they believe it's possible the accused is a witch,
                    ; they now believe the accused is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            [?ag](witch ?defender)
                            <?ag>(witch ?acsd)
                        )
                        [?ag](witch ?acsd)
                    )
                    ; if agent doesn't believe it's possible the defender is a witch, 
                    ; and they believe the accused is a witch,
                    ; they now don't believe the accused is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            !<?ag>(witch ?defender)
                            [?ag](witch ?acsd)
                        )
                        ![?ag](witch ?acsd)
                    )
                )
            )            
        )
    )

    (:action desire-to-defend-threatened
        :derive-condition never
        :parameters (?defender ?acsd ?acsr - agent)
        :precondition (and 
            (threatened-by ?defender ?acsd)
            (accused-by ?acsd ?acsr)
            [?defender](accused-by ?acsd ?acsr)
            (diff ?defender ?acsd)
            (diff ?defender ?acsr)
            (diff ?acsd ?acsr)
        )
        :effect (and 
            (desire-defend-threatened ?defender ?acsd ?acsr)
        )
    )
    (:action intend-to-defend-threatened
        :derive-condition never
        :parameters (?defender ?acsd ?acsr - agent)
        :precondition (and 
            (desire-defend-threatened ?defender ?acsd ?acsr)
        )
        :effect (and 
            (intend-defend-threatened ?defender ?acsd ?acsr)
        )
    )

    (:action defend-threatened
        :derive-condition never
        :parameters (?defender ?acsd ?acsr - agent ?l - loc)
        :precondition (and 
            (intend-defend-threatened ?defender ?acsd ?acsr)
            (at ?defender ?l)
            (at ?acsd ?l)
        )
        :effect (and 
            (forall ?ag - agent (and
                    (when (at ?ag ?l) [?ag](accused-by ?acsd ?acsr))
                    ; if agent believes it's possible the defender is a witch,
                    ; and they strongly believe the accused is a witch, 
                    ; they now believe the defender is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            ; note: this could include the original accuser
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            [?ag](witch ?acsd)
                            <?ag>(witch ?defender)
                        )
                        [?ag](witch ?defender)
                    )
                    ; if agent doesn't believe it's possible the accused is a witch, 
                    ; and they believe the defender is a witch,
                    ; they now don't believe the defender is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            !<?ag>(witch ?acsd)
                            [?ag](witch ?defender)
                        )
                        ![?ag](witch ?defender)
                    )
                    ; if agent strongly believes the defender is a witch, 
                    ; and they believe it's possible the accused is a witch,
                    ; they now believe the accused is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            [?ag](witch ?defender)
                            <?ag>(witch ?acsd)
                        )
                        [?ag](witch ?acsd)
                    )
                    ; if agent doesn't believe it's possible the defender is a witch, 
                    ; and they believe the accused is a witch,
                    ; they now don't believe the accused is a witch
                    (when (and 
                            (civilian ?ag) 
                            (at ?ag ?l)
                            (diff ?ag ?defender)
                            (diff ?ag ?acsd)
                            !<?ag>(witch ?defender)
                            [?ag](witch ?acsd)
                        )
                        ![?ag](witch ?acsd)
                    )
                )
            )            
        )
    )
   
    (:action copy-desire-to-defend-earnestly
        :derive-condition never
        :parameters (?syc ?a2 ?acsd ?acsr - agent ?l - loc)
        :precondition (and 
            (sycophant ?syc ?a2)
            (civilian ?syc)
            (at ?syc ?l)
            (at ?a2 ?l)
            (diff ?syc ?a2)
            (diff ?syc ?acsd)
            (diff ?syc ?acsr)
            [?syc](accused-by ?acsd ?acsr)
            (desire-defend-earnestly ?a2 ?acsd ?acsr)
        )
        :effect (and 
            (desire-defend-earnestly ?syc ?acsd ?acsr)
            !<?syc>(witch ?acsd)
        )
    )

    (:action copy-desire-to-defend-threatened
        :derive-condition never
        :parameters (?syc ?a2 ?acsd ?acsr - agent ?l - loc)
        :precondition (and 
            (sycophant ?syc ?a2)
            (civilian ?syc)
            (at ?syc ?l)
            (at ?a2 ?l)
            (diff ?syc ?a2)
            (diff ?syc ?acsd)
            (diff ?syc ?acsr)
            [?syc](accused-by ?acsd ?acsr)
            (desire-defend-threatened ?a2 ?acsd ?acsr)
        )
        :effect (and 
            (desire-defend-threatened ?syc ?acsd ?acsr)
        )
    )

    ; witch at the same location an item is at can collect that item
    (:action collect-item
        :derive-condition never
        :parameters (?w - agent ?i - item ?l - loc)
        :precondition (and (at ?w ?l) (item-at ?i ?l) (witch ?w) (not (collected ?i)))
        :effect (and 
            (collected ?i)
            ; agents at that location that witness the witch collecting the item become 1 level of more suspicious
            (forall (?ag - agent) 
                (and
                    (when 
                        (and 
                            (at ?ag ?l)
                            (civilian ?ag)
                            <?ag>(witch ?w)
                        )
                        [?ag](witch ?w)
                    )
                    (when 
                        (and 
                            (at ?ag ?l)
                            (civilian ?ag) 
                            !<?ag>(witch ?w)
                        )
                        <?ag>(witch ?w)
                    )
                    (when
                        (and
                            (at ?ag ?l)
                            (civilian ?ag) 
                            (not (stealthy ?ag))
                        )
                        [?w][?ag](witch ?w)
                    )
                    ; these outcomes are commented out b/c depth of 3 is slow/inconsistent to get working
                    ; see "flee-problem.pdkbddl"
                    ; (when
                    ;     (and
                    ;         (at ?ag ?l)
                    ;         (civilian ?ag)
                    ;         (not (stealthy ?ag))
                    ;         <?ag>(witch ?w)
                    ;     )
                    ;     [?ag][?w][?ag](witch ?w)
                    ; )
                    ; (when
                    ;     (and
                    ;         (at ?ag ?l)
                    ;         (civilian ?ag)
                    ;         (stealthy ?ag)
                    ;         (paranoid ?ag)
                    ;         <?ag>(witch ?w)
                    ;     )
                    ;     <?ag>[?w][?ag](witch ?w)
                    ; )
                )

            )
        )
    )

    ; note: ?c might not necessarily believe or even think it possible that ?w is a witch. 
    ; it's possible they lied about ?w, but ?w was actually a witch who now thinks ?c is onto them.
    ; but now, obviously, they know
    (:action witch-whisper-threat-suspicious
        :derive-condition never
        :parameters (?c ?w - agent ?l - loc)
        :precondition (and 
            (diff ?c ?w)
            (civilian ?c) 
            (witch ?w) 
            (not (threatened-by ?c ?w))
            [?w][?c](witch ?w)
            (at ?c ?l)
            (at ?w ?l)
        )
        :effect (and 
            (threatened-by ?c ?w)
            [?c](witch ?w)
        )
    )

    (:action witch-whisper-threat-to-accuser
        :derive-condition never
        :parameters (?c ?w - agent ?l - loc)
        :precondition (and 
            (diff ?c ?w)
            (civilian ?c) 
            (witch ?w) 
            (accused-by ?w ?c)
            [?w](accused-by ?w ?c)
            (at ?c ?l)
            (at ?w ?l)
        )
        :effect (and 
            (threatened-by ?c ?w)
            [?c](witch ?w)
        )
    )

    ; action for witch to tell another witch if another civilian believes they are a witch
    (:action witch-inform-witch-suspicious
        :derive-condition never
        :parameters (?w1 ?w2 ?c - agent ?l - loc)
        :precondition (and 
            (witch ?w1)
            (witch ?w2)
            (civilian ?c)
            [?w1][?c](witch ?w2)
            (at ?w1 ?l)
            (at ?w2 ?l)
        )
        :effect (and 
            [?w2][?c](witch ?w2)
        )
    )

    ; action for witch to tell another witch if another civilian accused them
    (:action witch-inform-witch-accused
        :derive-condition never
        :parameters (?w1 ?w2 ?acsr - agent ?l - loc)
        :precondition (and 
            (witch ?w1)
            (witch ?w2)
            (accused-by ?w2 ?acsr)
            [?w1](accused-by ?w2 ?acsr)
            (at ?w1 ?l)
            (at ?w2 ?l)
        )
        :effect (and 
            [?w2](accused-by ?w2 ?acsr)
        )
    )

    (:action hunt-witch-strong-belief
        :derive-condition never
        :parameters (?a1 ?a2 - agent)
        :precondition (and 
            (diff ?a1 ?a2)
            [?a1](witch ?a2)
        )
        :effect (and (witch-hunting ?a1 ?a2))
    )

    (:action hunt-witch-paranoid
        :derive-condition never
        :parameters (?a1 ?a2 - agent)
        :precondition (and 
            (diff ?a1 ?a2)
            <?a1>(witch ?a2)
            (paranoid ?a1)
        )
        :effect (and (witch-hunting ?a1 ?a2))
    )

    (:action hunt-witch-lying-hatred
        :derive-condition never
        :parameters (?a1 ?a2 - agent)
        :precondition (and 
            (diff ?a1 ?a2)
            !<?a1>(witch ?a2)
            (hates ?a1 ?a2)
        )
        :effect (and (witch-hunting ?a1 ?a2))
    )

    (:action hunt-witch-accused
        :derive-condition never
        :parameters (?a1 ?a2 - agent)
        :precondition (and 
            (diff ?a1 ?a2)
            (intend-accuse-random-accused ?a1 ?a2) 
        )
        :effect (and (witch-hunting ?a1 ?a2))
    )

    (:action desire-flee
        :derive-condition never
        :parameters (?a1 ?a2 - agent)
        :precondition (and 
            (civilian ?a1)
            (threatened-by ?a1 ?a2)
        )
        :effect (and 
            (desire-flee ?a1)
        )
    )

    (:action intend-flee
        :derive-condition never
        :parameters (?a1 - agent)
        :precondition (and 
            (desire-flee ?a1)            
        )
        :effect (and 
            (intend-flee ?a1)
        )
    )

    (:action copy-desire-to-flee
        :derive-condition never
        :parameters (?a1 ?a2 - agent ?l - loc)
        :precondition (and 
            (sycophant ?a1 ?a2)
            (civilian ?a1)
            (diff ?a1 ?a2)
            (at ?a1 ?l)
            (at ?a2 ?l)
            (desire-flee ?a2)
        )
        :effect (and 
            (desire-flee ?a1)
        )
    )

    (:action flee
        :derive-condition never
        :parameters (?a1 - agent ?l - loc)
        :precondition (and 
            (intend-flee ?a1)
            (at ?a1 ?l)
            (town-exit ?l)
        )
        :effect (and 
            (fled ?a1)
        )
    )
)