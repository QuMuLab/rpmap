        (!defeated bob)
        (!defeated cindy)
        (!defeated derek)

        !<i, alice>(fight alice alice island)
        !<i, alice>(fight alice bob island)
        !<i, bob>(fight bob bob island)
        !<i, bob>(fight bob alice island)

        [d, alice](got-treasure alice jewelry)
        [d, bob](got-treasure bob jewelry)
        (stronger alice cindy)
        (stronger alice derek)
        (stronger alice evelyn)
        (stronger cindy bob)
        (stronger derek bob)
        (stronger evelyn bob)
    )

    (:goal 
        (defeated cindy)
        (defeated derek)
        (defeated evelyn)
        (defeated bob)
